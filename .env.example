# Copy to .env — no paid API keys required, ever.

# ── LLM model (Ollama) ────────────────────────────────────────────────────
# Pick any model supported by Ollama. First run pulls it automatically.
#
#  Fast / lightweight (recommended for laptops):
#    llama3.1:8b        (default, ~5 GB)
#    deepseek-r1:7b     (~4 GB)
#    mistral            (~4 GB)
#    qwen2.5:7b         (~4.5 GB)
#
#  High accuracy (needs 16–40 GB RAM):
#    llama3.3:70b
#    qwen2.5:72b
#    mixtral:8x7b
#
OLLAMA_MODEL=llama3.1:8b

# ── Database (Docker only — local dev uses SQLite automatically) ──────────
POSTGRES_USER=autotriage
POSTGRES_PASSWORD=change_me_before_use
POSTGRES_DB=autotriage
